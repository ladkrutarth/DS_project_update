# Veriscan Environment Configuration Template

# --- Base Settings ---
ENV=development
DEBUG=true
VERISCAN_FAST_MODE=false

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
VERISCAN_API_URL=http://localhost:8000

# --- LLM Models ---
# MLX-specific IDs
# DEFAULT_LLM_MODEL=mlx-community/Meta-Llama-3-8B-Instruct-4bit
# FAST_LLM_MODEL=mlx-community/Llama-3.2-1B-Instruct-4bit
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=500

# --- RAG Engine ---
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_CFPB_INDEX_ROWS=1000
RAG_CONFIDENCE_THRESHOLD=0.4

# --- Financial Advisor & Credit ---
ADVISOR_SAVINGS_TARGET=100.0
ADVISOR_TREND_THRESHOLD_PCT=5.0
CREDIT_BASE_SCORE=680
CREDIT_UTILIZATION_THRESHOLD=0.3

# --- Aesthetics ---
PRIMARY_COLOR=#6366f1
SECONDARY_COLOR=#a855f7
CHART_TEXT_COLOR=#0f172a
TEXT_COLOR_MAIN=#1e293b
TEXT_COLOR_DARK=#0f172a
BG_COLOR_LIGHT=#f8fafc

# --- Hardware & Stability ---
VERISCAN_DEVICE=auto
VERISCAN_FORCE_CPU=false
